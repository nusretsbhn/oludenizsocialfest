<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Program — Electrofest Yönetim</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin">
  <%- include('../partials/admin-sidebar', { active: 'schedule' }) %>
  <main class="admin-main">
    <div class="admin-header">
      <h1>Program</h1>
    </div>

    <% if (success) { %>
      <div class="alert-success">Değişiklikler başarıyla kaydedildi.</div>
    <% } %>

    <div class="card">
      <h2>Program Öğesi Ekle</h2>
      <form method="POST" action="/admin/schedule">
        <div class="form-row">
          <div class="form-group">
            <label for="day">Gün</label>
            <select id="day" name="day" required>
              <% for (let d = 1; d <= 5; d++) { %>
                <option value="<%= d %>"><%= d %>. Gün</option>
              <% } %>
            </select>
          </div>
          <div class="form-group">
            <label for="date">Tarih</label>
            <input type="text" id="date" name="date" placeholder="20 Aralık 2026">
          </div>
          <div class="form-group">
            <label for="startTime">Başlangıç Saati</label>
            <input type="text" id="startTime" name="startTime" placeholder="21:00">
          </div>
          <div class="form-group">
            <label for="order">Sıra</label>
            <input type="number" id="order" name="order" value="0">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="artistName">Sanatçı Adı</label>
            <input type="text" id="artistName" name="artistName" required>
          </div>
          <div class="form-group">
            <label for="stage">Sahne</label>
            <input type="text" id="stage" name="stage" placeholder="Ana Sahne">
          </div>
        </div>
        <button type="submit" class="btn btn-primary">Ekle</button>
      </form>
    </div>

    <% const days = Object.keys(scheduleByDay).map(Number).sort((a, b) => a - b); %>
    <% if (days.length) { %>
      <% days.forEach(day => { %>
        <details class="schedule-day" open>
          <summary><%= day %>. Gün<% if (scheduleByDay[day][0] && scheduleByDay[day][0].date) { %> — <%= scheduleByDay[day][0].date %><% } %></summary>
          <table class="admin-table">
            <thead>
              <tr>
                <th>Saat</th>
                <th>Sanatçı</th>
                <th>Sahne</th>
                <th>Sıra</th>
                <th>İşlemler</th>
              </tr>
            </thead>
            <tbody>
              <% scheduleByDay[day].forEach(item => { %>
                <tr>
                  <td><%= item.startTime || '—' %></td>
                  <td><%= item.artistName %></td>
                  <td><%= item.stage || '—' %></td>
                  <td><%= item.order %></td>
                  <td>
                    <form method="POST" action="/admin/schedule/<%= item._id %>/delete" onsubmit="return confirm('Bu öğe silinsin mi?')">
                      <button type="submit" class="btn btn-danger btn-sm">Sil</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </details>
      <% }) %>
    <% } else { %>
      <p style="color:#666;">Henüz program öğesi yok.</p>
    <% } %>
  </main>
</body>
</html>
