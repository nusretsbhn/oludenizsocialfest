<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sanatçılar — Electrofest Yönetim</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin">
  <%- include('../partials/admin-sidebar', { active: 'artists' }) %>
  <main class="admin-main">
    <div class="admin-header">
      <h1>Sanatçılar</h1>
    </div>

    <% if (success) { %>
      <div class="alert-success">Değişiklikler başarıyla kaydedildi.</div>
    <% } %>

    <div class="card">
      <h2>Sanatçı Ekle</h2>
      <form method="POST" action="/admin/artists" enctype="multipart/form-data">
        <div class="form-row">
          <div class="form-group">
            <label for="name">Ad</label>
            <input type="text" id="name" name="name" required>
          </div>
          <div class="form-group">
            <label for="role">Rol</label>
            <input type="text" id="role" name="role" placeholder="DJ, Canlı Performans...">
          </div>
          <div class="form-group">
            <label for="order">Sıra</label>
            <input type="number" id="order" name="order" value="0">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="image">Görsel</label>
            <input type="file" id="image" name="image" accept="image/*">
          </div>
          <div class="form-group form-check" style="align-self: end;">
            <input type="checkbox" id="featured" name="featured">
            <label for="featured">Öne Çıkan</label>
          </div>
        </div>
        <button type="submit" class="btn btn-primary">Sanatçı Ekle</button>
      </form>
    </div>

    <table class="admin-table">
      <thead>
        <tr>
          <th>Görsel</th>
          <th>Ad</th>
          <th>Rol</th>
          <th>Öne Çıkan</th>
          <th>Sıra</th>
          <th>İşlemler</th>
        </tr>
      </thead>
      <tbody>
        <% artists.forEach(artist => { %>
          <tr>
            <td>
              <% if (artist.image) { %>
                <img src="<%= artist.image %>" alt="<%= artist.name %>" class="thumb">
              <% } else { %>
                <div class="thumb-placeholder"></div>
              <% } %>
            </td>
            <td><%= artist.name %></td>
            <td><%= artist.role || '—' %></td>
            <td><%= artist.featured ? 'Evet' : 'Hayır' %></td>
            <td><%= artist.order %></td>
            <td class="actions">
              <button type="button" class="btn btn-secondary btn-sm" data-edit-toggle="edit-<%= artist._id %>">Düzenle</button>
              <form method="POST" action="/admin/artists/<%= artist._id %>/delete" onsubmit="return confirm('Bu sanatçı silinsin mi?')">
                <button type="submit" class="btn btn-danger btn-sm">Sil</button>
              </form>
            </td>
          </tr>
          <tr>
            <td colspan="6" style="padding: 0; border: none;">
              <form id="edit-<%= artist._id %>" class="edit-form" method="POST" action="/admin/artists/<%= artist._id %>" enctype="multipart/form-data">
                <div class="form-row">
                  <div class="form-group">
                    <label>Ad</label>
                    <input type="text" name="name" value="<%= artist.name %>" required>
                  </div>
                  <div class="form-group">
                    <label>Rol</label>
                    <input type="text" name="role" value="<%= artist.role || '' %>">
                  </div>
                  <div class="form-group">
                    <label>Sıra</label>
                    <input type="number" name="order" value="<%= artist.order %>">
                  </div>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label>Yeni Görsel (isteğe bağlı)</label>
                    <input type="file" name="image" accept="image/*">
                  </div>
                  <div class="form-group form-check" style="align-self: end;">
                    <input type="checkbox" name="featured" id="featured-<%= artist._id %>" <%= artist.featured ? 'checked' : '' %>>
                    <label for="featured-<%= artist._id %>">Öne Çıkan</label>
                  </div>
                </div>
                <button type="submit" class="btn btn-primary btn-sm">Değişiklikleri Kaydet</button>
              </form>
            </td>
          </tr>
        <% }) %>
        <% if (!artists.length) { %>
          <tr><td colspan="6" style="text-align:center;color:#666;">Henüz sanatçı yok.</td></tr>
        <% } %>
      </tbody>
    </table>
  </main>
  <script src="/js/admin.js"></script>
</body>
</html>
